<aura:component implements="flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId" access="global" >
	
    <aura:attribute name="recordId" type="String"/>
    
    <aura:attribute name="relatedListSettingName" type="String"/>
    <aura:attribute name="overrideNewButton" type="String"/>
	<aura:if isTrue="{!and(v.relatedListSettingName != null,v.overrideNewButton != null)}">
	<ucinn_ascendv2:RelatedList recordId="{!v.recordId}"
                                relatedListSettingName="{!v.relatedListSettingName}"
                                outsideAscendPackage="true"
                                overrideNewButton = "{!v.overrideNewButton}"
                                />
	</aura:if>
</aura:component>